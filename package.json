{
  "name": "electron-job-addon",
  "version": "1.0.0",
  "description": "Native addon for Windows Job Objects in Electron",
  "main": "js/index.js",
  "types": "js/index.d.ts",
  "scripts": {
    "clean": "if exist build rmdir /s /q build",
    "build": "node-gyp configure && node-gyp build",
    "rebuild": "npm run clean && npm run build",
    "rebuild:electron": "electron-rebuild -v 41.0.3",
    "install": "node-gyp rebuild",
    "prebuild": "prebuild --runtime electron --target 41.0.3 --all --strip --verbose",
    "prebuild:upload": "prebuild --runtime electron --target 41.0.3 --all --upload-all"
  },
  "binary": {
    "napi_versions": [
      8
    ],
    "module_name": "job_addon",
    "module_path": "./bin/{platform}-{arch}-{napi_version}",
    "host": "https://github.com/{owner}/{repo}/releases/download/v{version}",
    "remote_path": "./v{version}"
  },
  "files": [
    "bin/",
    "js/",
    "src/",
    "include/",
    "binding.gyp",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "electron",
    "native",
    "addon",
    "windows",
    "job-object",
    "process-management",
    "node-gyp",
    "napi"
  ],
  "author": "yar3333",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yar3333/electron-job-addon.git"
  },
  "bugs": {
    "url": "https://github.com/yar3333/electron-job-addon/issues"
  },
  "homepage": "https://github.com/yar3333/electron-job-addon#readme",
  "os": [
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "dependencies": {
    "bindings": "^1.5.0",
    "node-addon-api": "^8.3.0",
    "prebuild-install": "^7.1.2"
  },
  "devDependencies": {
    "electron-rebuild": "^3.2.9",
    "node-gyp": "^10.0.0",
    "prebuild": "^13.0.0"
  }
}
